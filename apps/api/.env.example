PORT=6001
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/<db_name>?schema=public

APP_FALLBACK_LANG=id

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
