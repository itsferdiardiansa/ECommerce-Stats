{
  "info": {
    "name": "Auth",
    "_postman_id": "rufieltics-api-collection",
    "description": "Complete API collection for Rufieltics application including Authentication and User Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:6001/api/v1",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "verification_code",
      "value": "123456",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "lockout_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "login_lockout_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "description": "Authentication endpoints for registration, login, and email verification",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "en",
                "description": "Language: en (English) or id (Indonesian)"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"username\": \"johndoe\",\n  \"password\": \"SecurePass123!\",\n  \"name\": \"John Doe\",\n  \"phone\": \"+1234567890\",\n  \"avatar\": \"https://example.com/avatar.jpg\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "description": "Register a new user account. User will be created with isActive=false and requires email verification. A 6-digit verification code will be sent to the provided email address."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.id) {",
                  "        pm.collectionVariables.set('user_id', response.data.id);",
                  "        console.log('User ID saved: ' + response.data.id);",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"code\": \"{{verification_code}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/verify-email",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify-email"]
            },
            "description": "Verify email address with the 6-digit code received via email. Upon successful verification, the user's isActive will be set to true and emailVerifiedAt will be updated."
          },
          "response": []
        },
        {
          "name": "Resend Verification Code",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/resend-verification",
              "host": ["{{base_url}}"],
              "path": ["auth", "resend-verification"]
            },
            "description": "Resend verification code to the email address. The previous code will be invalidated and a new 6-digit code will be sent. Rate limited to 3 requests per hour per email."
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Login with email and password. Returns access token and refresh token. Only active users (isActive=true) can login."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.accessToken) {",
                  "        pm.collectionVariables.set('access_token', response.data.accessToken);",
                  "        console.log('Access token saved');",
                  "    }",
                  "    }"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Exchange a valid refresh token for a new access + refresh token pair. The used refresh token is immediately invalidated (single-use rotation). If the same refresh token is used twice, both are revoked."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.accessToken) {",
                  "        pm.collectionVariables.set('access_token', response.data.accessToken);",
                  "        console.log('New access token saved');",
                  "    }",
                  "    }"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "description": "Required — valid access token"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            },
            "description": "Revokes the current session. Deletes the refresh token from Redis and marks the DB session as isRevoked=true. Subsequent /auth/refresh calls with the same token will return 401."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    pm.collectionVariables.set('access_token', '');",
                  "    pm.collectionVariables.set('refresh_token', '');",
                  "    console.log('Tokens cleared after logout');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Revoke Other Sessions",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/sessions/others",
              "host": ["{{base_url}}"],
              "path": ["auth", "sessions", "others"]
            }
          },
          "response": []
        },
        {
          "name": "Revoke Sessions",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jtis\": [\n    \"ENTER-UUID-HERE\"\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/sessions",
              "host": ["{{base_url}}"],
              "path": ["auth", "sessions"]
            }
          },
          "response": []
        },
        {
          "name": "Get Active Sessions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/sessions",
              "host": ["{{base_url}}"],
              "path": ["auth", "sessions"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin - Lockout Management",
      "description": "Admin-only endpoints for managing verification lockouts",
      "item": [
        {
          "name": "List All Lockouts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "description": "Admin access token required"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/lockouts?page=1&limit=10&status=active",
              "host": ["{{base_url}}"],
              "path": ["admin", "lockouts"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (default: 1)"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Items per page (max: 100, default: 10)"
                },
                {
                  "key": "status",
                  "value": "active",
                  "description": "Filter by status: active, cleared, or all (default: active)"
                },
                {
                  "key": "email",
                  "value": "",
                  "description": "Filter by exact email address",
                  "disabled": true
                },
                {
                  "key": "reason",
                  "value": "",
                  "description": "Filter by reason: TOO_MANY_ATTEMPTS, SUSPICIOUS_ACTIVITY, MANUAL_LOCK",
                  "disabled": true
                },
                {
                  "key": "sortBy",
                  "value": "lockedAt",
                  "description": "Sort by: lockedAt, expires, or email (default: lockedAt)",
                  "disabled": true
                },
                {
                  "key": "sortOrder",
                  "value": "desc",
                  "description": "Sort order: asc or desc (default: desc)",
                  "disabled": true
                }
              ]
            },
            "description": "List all verification lockouts with pagination and filters. Admin privileges required. Returns email, IP address, user agent, reason, timestamps, and remaining time for active lockouts."
          },
          "response": []
        },
        {
          "name": "List Lockouts (Cleared Only)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/lockouts?status=cleared&page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["admin", "lockouts"],
              "query": [
                {
                  "key": "status",
                  "value": "cleared"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "List only cleared (resolved) lockouts with clearedAt and clearedBy information."
          },
          "response": []
        },
        {
          "name": "List Lockouts (By Email)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/lockouts?email=john.doe@example.com&status=all",
              "host": ["{{base_url}}"],
              "path": ["admin", "lockouts"],
              "query": [
                {
                  "key": "email",
                  "value": "john.doe@example.com",
                  "description": "Search lockouts for specific email"
                },
                {
                  "key": "status",
                  "value": "all",
                  "description": "Include both active and cleared"
                }
              ]
            },
            "description": "Find all lockouts (active and cleared) for a specific email address."
          },
          "response": []
        },
        {
          "name": "Get Lockout by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/lockouts/1",
              "host": ["{{base_url}}"],
              "path": ["admin", "lockouts", "1"]
            },
            "description": "Get detailed information about a specific lockout by ID. Admin privileges required."
          },
          "response": []
        },
        {
          "name": "Clear Lockout (Manual Unlock)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/lockouts/1",
              "host": ["{{base_url}}"],
              "path": ["admin", "lockouts", "1"]
            },
            "description": "Manually clear a lockout to allow the user to attempt verification again. Admin privileges required. Records the admin ID who cleared the lockout and removes it from both database and Redis."
          },
          "response": []
        },
        {
          "name": "Get My Lockout Status (User)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "description": "User's own access token"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/my-lockout",
              "host": ["{{base_url}}"],
              "path": ["auth", "my-lockout"]
            },
            "description": "Check your own verification lockout status. Returns whether you're locked, the reason, expiry time, and remaining seconds/minutes. Authenticated users only."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin - Login Lockout Management",
      "description": "Admin-only endpoints for managing login lockouts (TOO_MANY_ATTEMPTS, SUSPICIOUS_ACTIVITY, MANUAL_LOCK)",
      "item": [
        {
          "name": "Create Login Lockout (Manual Lock)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "description": "Admin access token required"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"ttlSeconds\": 3600\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/login-lockouts",
              "host": ["{{base_url}}"],
              "path": ["admin", "login-lockouts"]
            },
            "description": "Manually lock a user's login with reason MANUAL_LOCK. Optional ttlSeconds sets the lockout duration (max 604800 = 7 days). Defaults to progressive TTL based on prior lockout history if omitted."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    console.log('Manual login lockout created for: ' + response.data.email);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Login Lockouts (Active)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "description": "Admin access token required"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/login-lockouts?page=1&limit=10&status=active",
              "host": ["{{base_url}}"],
              "path": ["admin", "login-lockouts"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (default: 1)"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Items per page (max: 100, default: 10)"
                },
                {
                  "key": "status",
                  "value": "active",
                  "description": "Filter by status: active, cleared, or all (default: active)"
                },
                {
                  "key": "email",
                  "value": "",
                  "description": "Filter by exact email address",
                  "disabled": true
                },
                {
                  "key": "startDate",
                  "value": "",
                  "description": "Filter lockouts created on or after this date (ISO 8601)",
                  "disabled": true
                },
                {
                  "key": "endDate",
                  "value": "",
                  "description": "Filter lockouts created on or before this date (ISO 8601)",
                  "disabled": true
                },
                {
                  "key": "sortOrder",
                  "value": "desc",
                  "description": "Sort order: asc or desc (default: desc)",
                  "disabled": true
                }
              ]
            },
            "description": "List all login lockouts with pagination and filters. Returns reason (TOO_MANY_ATTEMPTS / SUSPICIOUS_ACTIVITY / MANUAL_LOCK), IP address, user agent, timestamps, and remaining seconds for active lockouts."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.data && response.data.data.length > 0) {",
                  "        pm.collectionVariables.set('login_lockout_id', response.data.data[0].id);",
                  "        console.log('First login lockout ID saved: ' + response.data.data[0].id);",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Login Lockouts (By Email)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/login-lockouts?email=john.doe@example.com&status=all",
              "host": ["{{base_url}}"],
              "path": ["admin", "login-lockouts"],
              "query": [
                {
                  "key": "email",
                  "value": "john.doe@example.com",
                  "description": "Search lockouts for specific email"
                },
                {
                  "key": "status",
                  "value": "all",
                  "description": "Include both active and cleared"
                }
              ]
            },
            "description": "Find all login lockouts (active and cleared) for a specific email address. Useful for reviewing the lockout history and understanding progressive escalation."
          },
          "response": []
        },
        {
          "name": "List Login Lockouts (Cleared Only)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/login-lockouts?status=cleared&page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["admin", "login-lockouts"],
              "query": [
                {
                  "key": "status",
                  "value": "cleared"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "List only cleared login lockouts with clearedAt and clearedBy information."
          },
          "response": []
        },
        {
          "name": "Get Login Lockout by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/login-lockouts/{{login_lockout_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "login-lockouts", "{{login_lockout_id}}"]
            },
            "description": "Get detailed information about a specific login lockout by ID, including reason, remaining time, and who cleared it (if cleared)."
          },
          "response": []
        },
        {
          "name": "Clear Login Lockout (Manual Unlock)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/login-lockouts/{{login_lockout_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "login-lockouts", "{{login_lockout_id}}"]
            },
            "description": "Manually clear a login lockout so the user can attempt login again. Clears all active login lockouts for that email and removes the Redis key. Records the admin ID who performed the clear."
          },
          "response": []
        }
      ]
    },
    {
      "name": "User Management",
      "description": "User CRUD operations and management endpoints (typically admin or self-only)",
      "item": [
        {
          "name": "List All Users (Basic)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["users"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "List all users with basic pagination."
          },
          "response": []
        },
        {
          "name": "List Users (With Search)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept-Language",
                "value": "en"
              }
            ],
            "url": {
              "raw": "{{base_url}}/users?search=john&page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["users"],
              "query": [
                {
                  "key": "search",
                  "value": "john",
                  "description": "Searches in name, email, and username fields"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Search users by name, email, or username."
          },
          "response": []
        },
        {
          "name": "List Users (With Filters)",
          "request": {
            "method": "GET",
